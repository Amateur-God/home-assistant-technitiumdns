{
  "domain": "technitiumdns",
  "name": "TechnitiumDNS",
  "codeowners": [
    "@Amateur-God"
  ],
  "config_flow": true,
  "dependencies": [],
  "documentation": "https://github.com/Amateur-God/home-assistant-Technitiumdns",
  "integration_type": "device",
  "iot_class": "local_polling",
  "issue_tracker": "https://github.com/Amateur-God/home-assistant-Technitiumdns/issues",
  "requirements": ["aiohttp>=3.9.0"],
  "version": "2.3.0",
  "resources": [
    {
      "type": "module",
      "url": "/local/statistics_card.js",
      "path": "custom_components/technitiumdns/statistics_card.js"
    },
    {
      "type": "module",
      "url": "/local/top_clients_card.js",
      "path": "custom_components/technitiumdns/top_clients_card.js"
    },
    {
      "type": "module",
      "url": "/local/top_domains_card.js",
      "path": "custom_components/technitiumdns/top_domains_card.js"
    },
    {
      "type": "module",
      "url": "/local/top_blocked_domains_card.js",
      "path": "custom_components/technitiumdns/top_blocked_domains_card.js"
    }
  ]
}
